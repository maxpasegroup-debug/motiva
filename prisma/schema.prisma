// Motiva Edus — Prisma schema
// Migration target: replaces data/auth-users.json and data/programs.json
// with PostgreSQL tables, and adds audit_log, payment_transactions,
// mentor_notes, learning_plans, class_schedules, issues, messages.
//
// Existing tables (admins … admissions) are modelled here so Prisma
// Client can query them; they already exist in the database.
//
// How to apply:
//   New database   → npx prisma migrate dev --name init
//   Existing DB    → npx prisma db push   (schema-drift reconciliation)
//   Data migration → npx tsx scripts/migrate-json-to-db.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEGACY ADMIN TABLE  (001_admins.sql — kept for backwards compatibility)
// ─────────────────────────────────────────────────────────────────────────────

model Admin {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.Text
  role         String @default("admin") @db.VarChar(32)

  @@map("admins")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS  — migration target for data/auth-users.json
// All roles live here: admin, teacher, student, parent,
// telecounselor, demo_executive, mentor
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(255)
  mobile           String?  @db.VarChar(16)
  email            String?  @unique @db.VarChar(255)
  username         String?  @unique @db.VarChar(64)
  phone            String?  @db.VarChar(64)
  pin              String?  @db.Text
  role             String   @default("public") @db.VarChar(32)
  isActive         Boolean  @default(true) @map("is_active")
  pinResetRequired Boolean  @default(false) @map("pin_reset_required")
  createdBy        String?  @map("created_by") @db.VarChar(255)
  profileData      Json?    @map("profile_data")
  passwordHash     String?  @map("password_hash") @db.Text
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pinResetRequests PinResetRequest[]

  courseEnrollments CourseEnrollment[]
  createdStudentAccounts StudentAccount[] @relation("StudentAccountCreatedBy")
  mentoredStudentAccounts StudentAccount[] @relation("StudentAccountMentor")
  taughtStudentAccounts StudentAccount[] @relation("StudentAccountTeacher")
  createdParentAccounts ParentAccount[] @relation("ParentAccountCreatedBy")
  assignedMentorLeads Lead[] @relation("LeadAssignedMentor")
  studentAccount StudentAccount? @relation("StudentUser")
  parentAccount ParentAccount? @relation("ParentUser")

  @@index([role])
  @@index([mobile])
  @@map("users")
}

model UnifiedUser {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(255)
  mobile           String   @unique @db.VarChar(16)
  pin              String   @db.Text
  role             String   @default("public") @db.VarChar(32)
  isActive         Boolean  @default(true) @map("is_active")
  pinResetRequired Boolean  @default(false) @map("pin_reset_required")
  createdBy        String?  @map("created_by") @db.VarChar(255)
  profileData      Json?    @map("profile_data")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([mobile])
  @@index([role])
  @@map("unified_users")
}

model PinResetRequest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  mobile      String   @db.VarChar(16)
  status      String   @default("pending") @db.VarChar(16)
  requestedAt DateTime @default(now()) @map("requested_at") @db.Timestamptz
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz
  resolvedBy  String?  @map("resolved_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, requestedAt(sort: Desc)])
  @@index([userId])
  @@map("pin_reset_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// RECORDED COURSES  — on-demand video curriculum (admin builder + enrollments)
// ─────────────────────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(512)
  thumbnail   String   @db.Text
  description String   @db.Text
  targetRole  String   @map("target_role") @db.VarChar(32)
  price       Float    @default(0)
  status      String   @default("draft") @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sections    CourseSection[]
  enrollments CourseEnrollment[]

  @@index([status])
  @@index([targetRole])
  @@map("courses")
}

model CourseSection {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  type         String   @db.VarChar(16)
  sectionTitle String   @map("section_title") @db.VarChar(512)
  order        Int
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  videos CourseVideo[]

  @@index([courseId, order])
  @@map("course_sections")
}

model CourseVideo {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId   String   @map("section_id") @db.Uuid
  videoTitle  String   @map("video_title") @db.VarChar(512)
  videoUrl    String   @map("video_url") @db.Text
  description String   @db.Text
  order       Int
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, order])
  @@map("course_videos")
}

model CourseEnrollment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  enrolledAt DateTime @default(now()) @map("enrolled_at") @db.Timestamptz
  progress   Int      @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_enrollments")
}

model Teacher {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  subject      String   @db.VarChar(255)
  bio          String?  @db.Text
  photo        String?  @db.Text
  displayOrder Int      @default(0) @map("display_order")
  isVisible    Boolean  @default(true) @map("is_visible")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([displayOrder, createdAt])
  @@map("teachers")
}

model Enquiry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(255)
  mobile          String   @db.VarChar(32)
  programInterest String   @map("program_interest") @db.VarChar(128)
  message         String?  @db.Text
  status          String   @default("new") @db.VarChar(32)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, createdAt(sort: Desc)])
  @@map("enquiries")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROGRAMS  — migration target for data/programs.json
// ─────────────────────────────────────────────────────────────────────────────

model Program {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(512)
  description String   @db.Text
  imagePath   String   @default("") @map("image_path") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("programs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMISSION REQUESTS  — public enrollment form (002_admission_requests.sql)
// ─────────────────────────────────────────────────────────────────────────────

model AdmissionRequest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentName String   @map("student_name") @db.VarChar(255)
  parentName  String   @map("parent_name") @db.VarChar(255)
  phone       String   @db.VarChar(64)
  programId   String   @map("program_id") @db.VarChar(64)
  status      String   @default("pending") @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("admission_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// BATCHES & ROSTERS  (005_batches.sql)
//
// duration is plain Int — any number of days is valid.
// The old CHECK (duration IN (12, 25)) constraint is intentionally removed.
// ─────────────────────────────────────────────────────────────────────────────

model Batch {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(512)
  teacherId     String    @map("teacher_id") @db.VarChar(255)
  duration      Int
  startDate     DateTime? @map("start_date") @db.Date
  unlockedDay   Int       @default(1) @map("unlocked_day")
  completedDays Int       @default(0) @map("completed_days")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  students   BatchStudent[]
  studentAccounts StudentAccount[]
  progress   BatchProgress?
  attendance Attendance[]
  schedules  ClassSchedule[]

  @@index([teacherId])
  @@map("batches")
}

// One row per student — a student belongs to at most one batch at a time.
model BatchStudent {
  studentId String @id @map("student_id") @db.VarChar(255)
  batchId   String @map("batch_id") @db.Uuid

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("batch_students")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTENDANCE & DAY PROGRESS  (006_attendance.sql)
// ─────────────────────────────────────────────────────────────────────────────

model BatchProgress {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId    String @unique @map("batch_id") @db.Uuid
  currentDay Int    @default(1) @map("current_day")

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("batch_progress")
}

model Attendance {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String   @map("student_id") @db.VarChar(255)
  batchId   String   @map("batch_id") @db.Uuid
  dayNumber Int      @map("day_number")
  status    String   @db.VarChar(20)
  markedBy  String   @map("marked_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([studentId, batchId, dayNumber], name: "attendance_student_batch_day_unique")
  @@index([batchId, dayNumber])
  @@index([batchId])
  @@map("attendance")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARENTS & NOTIFICATIONS  (007_parent_portal.sql)
//
// parents.id mirrors the auth user ID (VARCHAR, not auto-UUID).
// ─────────────────────────────────────────────────────────────────────────────

model Parent {
  id              String   @id @db.VarChar(255)
  name            String   @db.VarChar(255)
  phone           String   @db.VarChar(64)
  phoneNormalized String   @map("phone_normalized") @db.VarChar(32)
  studentId       String   @unique @map("student_id") @db.VarChar(255)
  email           String?  @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  notifications ParentNotification[]

  @@index([phoneNormalized])
  @@map("parents")
}

model ParentNotification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId  String   @map("parent_id") @db.VarChar(255)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  isRead    Boolean  @default(false) @map("is_read")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId, createdAt(sort: Desc)])
  @@map("parent_notifications")
}

model StudentPaymentStatus {
  studentId String   @id @map("student_id") @db.VarChar(255)
  status    String   @default("pending") @db.VarChar(20)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("student_payment_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT TRANSACTIONS
// DB replacement for the localStorage payments ledger.
// Stores individual payment records with full history.
// ─────────────────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId      String?  @map("lead_id") @db.Uuid
  orderId     String?  @map("order_id") @db.VarChar(255)
  razorpayPaymentId String? @map("razorpay_payment_id") @db.VarChar(255)
  studentId   String   @map("student_id") @db.VarChar(255)
  studentName String   @map("student_name") @db.VarChar(255)
  courseLabel String   @map("course_label") @db.VarChar(255)
  amountCents Int      @map("amount_cents")
  currency    String   @default("INR") @db.VarChar(8)
  status      String   @default("pending") @db.VarChar(20)
  notes       String?  @db.Text
  recordedBy  String?  @map("recorded_by") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([leadId])
  @@index([studentId])
  @@index([orderId])
  @@index([razorpayPaymentId])
  @@index([status])
  @@map("payment_transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM  — leads, demos, pipeline admissions
// (tables created inline in leads-demos-admissions-db.ts)
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(255)
  phone      String   @db.VarChar(64)
  type       String   @db.VarChar(32)
  subjects   String?  @db.Text
  status     String   @default("new") @db.VarChar(32)
  flowType   String   @default("tuition") @map("flow_type") @db.VarChar(32)
  assignedTo String?  @map("assigned_to") @db.VarChar(255)
  assignedMentorId String? @map("assigned_mentor_id") @db.Uuid
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  demos      Demo[]
  admissions Admission[]
  assignedMentor User? @relation("LeadAssignedMentor", fields: [assignedMentorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedTo])
  @@index([flowType])
  @@index([assignedMentorId])
  @@map("leads")
}

model StudentAccount {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @unique @map("user_id") @db.Uuid
  studentName     String   @map("student_name") @db.VarChar(255)
  parentName      String   @map("parent_name") @db.VarChar(255)
  mobile          String   @unique @db.VarChar(16)
  email           String?  @db.VarChar(255)
  username        String   @unique @db.VarChar(64)
  pin             String   @db.Text
  pinResetRequired Boolean @default(false) @map("pin_reset_required")
  role            String   @default("student") @db.VarChar(32)
  batchId         String?  @map("batch_id") @db.Uuid
  mentorId        String?  @map("mentor_id") @db.Uuid
  teacherId       String?  @map("teacher_id") @db.Uuid
  programType     String   @map("program_type") @db.VarChar(32)
  admissionStatus String   @default("active") @map("admission_status") @db.VarChar(32)
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  batch          Batch?           @relation(fields: [batchId], references: [id], onDelete: SetNull)
  mentor         User?            @relation("StudentAccountMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  teacher        User?            @relation("StudentAccountTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  creator        User             @relation("StudentAccountCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  user           User?            @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  parentAccounts ParentAccount[]
  learningPlans  LearningPlan[]
  issues         Issue[]
  classSchedules ClassSchedule[]
  wellbeingEntries StudentWellbeing[]

  @@index([batchId])
  @@index([mentorId])
  @@index([teacherId])
  @@index([createdBy])
  @@index([programType])
  @@map("student_accounts")
}

model ParentAccount {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @unique @map("user_id") @db.Uuid
  name       String   @db.VarChar(255)
  mobile     String   @unique @db.VarChar(16)
  username   String   @unique @db.VarChar(64)
  pin        String   @db.Text
  role       String   @default("parent") @db.VarChar(32)
  studentId  String   @map("student_id") @db.Uuid
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  creator User           @relation("ParentAccountCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  user    User?          @relation("ParentUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([createdBy])
  @@map("parent_accounts")
}

model StudentWellbeing {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  rating    Int
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId, date(sort: Desc)])
  @@map("student_wellbeing")
}

model Demo {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId          String   @map("lead_id") @db.Uuid
  demoExecutiveId String   @map("demo_executive_id") @db.VarChar(255)
  status          String   @default("pending") @db.VarChar(32)
  result          String?  @db.VarChar(32)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([demoExecutiveId])
  @@map("demos")
}

model Admission {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId         String   @map("lead_id") @db.Uuid
  studentName    String   @map("student_name") @db.VarChar(255)
  parentName     String   @map("parent_name") @db.VarChar(255)
  phone          String   @db.VarChar(64)
  type           String   @db.VarChar(32)
  status         String   @default("pending") @db.VarChar(32)
  feeAmountCents Int?     @map("fee_amount_cents")
  feeCurrency    String?  @default("INR") @map("fee_currency") @db.VarChar(8)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Restrict)

  @@index([leadId])
  @@index([status])
  @@map("admissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG  — system-wide action trail for all admin and user actions
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.VarChar(255)
  actorRole  String?  @map("actor_role") @db.VarChar(32)
  action     String   @db.VarChar(128)
  entityType String?  @map("entity_type") @db.VarChar(64)
  entityId   String?  @map("entity_id") @db.VarChar(255)
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR NOTES  — mentor observations and progress notes per student
// ─────────────────────────────────────────────────────────────────────────────

model MentorNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorId  String   @map("mentor_id") @db.VarChar(255)
  studentId String   @map("student_id") @db.VarChar(255)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([mentorId])
  @@index([studentId])
  @@map("mentor_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEARNING PLANS  — structured plans assigned to a student
// ─────────────────────────────────────────────────────────────────────────────

model LearningPlan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  title       String    @default("Learning Plan") @db.VarChar(512)
  description String?   @db.Text
  batchId     String?   @map("batch_id") @db.Uuid
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  status      String    @default("active") @db.VarChar(32)
  subjects    Json?
  goals       String?   @db.Text
  revisionCycle String? @map("revision_cycle") @db.VarChar(32)
  notes       String?   @db.Text
  createdBy   String?   @map("created_by") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("learning_plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLASS SCHEDULES  — per-day scheduling metadata (topic, time) for a batch
// ─────────────────────────────────────────────────────────────────────────────

model ClassSchedule {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId     String?   @map("batch_id") @db.Uuid
  dayNumber   Int?      @map("day_number")
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz
  topic       String?   @db.VarChar(512)
  studentId   String?   @map("student_id") @db.Uuid
  teacherId   String?   @map("teacher_id") @db.Uuid
  mentorId    String?   @map("mentor_id") @db.Uuid
  subject     String?   @db.VarChar(255)
  classType   String?   @map("class_type") @db.VarChar(32)
  scheduledDate DateTime? @map("scheduled_date") @db.Date
  scheduledTime String? @map("scheduled_time") @db.VarChar(16)
  durationMinutes Int   @default(60) @map("duration_minutes")
  notes       String?   @db.Text
  status      String    @default("scheduled") @db.VarChar(32)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  batch   Batch?          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student StudentAccount? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([teacherId])
  @@index([mentorId])
  @@index([scheduledDate])
  @@index([batchId])
  @@map("class_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// ISSUES  — support tickets or reported problems raised by any role
// ─────────────────────────────────────────────────────────────────────────────

model Issue {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportedBy  String   @map("reported_by") @db.VarChar(255)
  assignedTo  String?  @map("assigned_to") @db.VarChar(255)
  studentId   String?  @map("student_id") @db.Uuid
  raisedById  String?  @map("raised_by_id") @db.Uuid
  assignedToId String? @map("assigned_to_id") @db.Uuid
  entityType  String?  @map("entity_type") @db.VarChar(64)
  entityId    String?  @map("entity_id") @db.VarChar(255)
  title       String   @db.VarChar(512)
  category    String?  @db.VarChar(32)
  description String?  @db.Text
  priority    String   @default("medium") @db.VarChar(16)
  status      String   @default("open") @db.VarChar(32)
  timeline    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student StudentAccount? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([reportedBy])
  @@index([assignedTo])
  @@index([studentId])
  @@index([raisedById])
  @@index([assignedToId])
  @@index([status])
  @@map("issues")
}

// ─────────────────────────────────────────────────────────────────────────────
// MESSAGES  — direct messages between any two users
// (student↔teacher, parent↔teacher, admin↔any, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model Message {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderId   String    @map("sender_id") @db.VarChar(255)
  receiverId String    @map("receiver_id") @db.VarChar(255)
  content    String    @db.Text
  isRead     Boolean   @default(false) @map("is_read")
  readAt     DateTime? @map("read_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId, createdAt(sort: Desc)])
  @@map("messages")
}
