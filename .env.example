# Motiva Edus — Environment Variables

# Primary PostgreSQL database used by Prisma and server-side data access.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret for unified auth cookies and bearer tokens. Use at least 32 characters.
JWT_SECRET=your-32-character-or-longer-jwt-secret

# Public app URL used by deployment platforms and generated links.
NEXTAUTH_URL=https://your-app.up.railway.app

# Cloudinary cloud name for teacher, course, and program media uploads.
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# Cloudinary API key for signed server-side uploads.
CLOUDINARY_API_KEY=your-cloudinary-api-key

# Cloudinary API secret for signed server-side uploads.
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# WhatsApp Business phone number ID used for API-based credential messages.
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# WhatsApp Business access token used for API-based credential messages.
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Public coordinator WhatsApp number used for forgot-PIN contact links.
WHATSAPP_CONTACT_NUMBER=919946930723

# Upstash Redis REST URL used for API rate limiting.
UPSTASH_REDIS_REST_URL=your_upstash_redis_url

# Upstash Redis REST token used for API rate limiting.
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Server-side Sentry DSN for optional error tracking.
SENTRY_DSN=https://your_dsn@sentry.io/project_id

# Browser Sentry DSN for optional client error tracking.
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id

# Node runtime mode for local development or production deployment.
NODE_ENV=development

# Railway environment name when deployed on Railway.
RAILWAY_ENVIRONMENT=development

# Razorpay key ID used for payment order creation.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Razorpay key secret used for payment verification.
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
