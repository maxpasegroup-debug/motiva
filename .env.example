# Copy to `.env` or `.env.local` and replace placeholders.
# Required in production unless noted otherwise.

# Primary database connection used by Prisma and server-side data access.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret for all auth tokens. Use at least 32 characters.
JWT_SECRET=your-32-character-or-longer-jwt-secret

# NextAuth compatibility values used by supporting scripts and hosting setup.
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-app.up.railway.app

# Cloudinary credentials for teacher/course media uploads.
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# WhatsApp Business API credentials for credential and notification messages.
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Upstash Redis credentials for API rate limiting.
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Sentry DSNs for optional server/client error tracking.
SENTRY_DSN=https://your_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id

# Optional bootstrap admin credentials (defaults are used if unset).
ADMIN_BOOT_EMAIL=admin@motiva.local
ADMIN_BOOT_PASSWORD=admin1234

# Runtime-provided in most environments (do not hardcode in production).
NODE_ENV=development
RAILWAY_ENVIRONMENT=development

# Razorpay credentials for payment order creation and verification.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
