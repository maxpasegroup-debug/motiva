# Copy to `.env` or `.env.local` and replace placeholders.
#
# Railway:
#   - Add each variable under your service → Variables.
#   - Set NEXTAUTH_URL to your public HTTPS URL (e.g. https://your-app.up.railway.app).
#   - Use a long random JWT_SECRET and NEXTAUTH_SECRET (no hardcoding in code).
#   - `npm start` runs scripts/railway-start.cjs → checks env + DB, then `next start`.

DATABASE_URL=your_postgresql_connection
JWT_SECRET=your_secret_key
NEXTAUTH_SECRET=your_secret_key
NEXTAUTH_URL=https://your-domain.com
