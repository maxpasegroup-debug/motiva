# Copy to `.env` or `.env.local` and replace placeholders.
# Required in production unless noted otherwise.

DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your-secret-here
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-app.up.railway.app

# Optional Cloudinary credentials (set if upload features use Cloudinary).
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional bootstrap admin credentials (defaults are used if unset).
ADMIN_BOOT_EMAIL=admin@motiva.local
ADMIN_BOOT_PASSWORD=admin1234

# Runtime-provided in most environments (do not hardcode in production).
NODE_ENV=development
RAILWAY_ENVIRONMENT=development

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
